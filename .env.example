# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# On Railway, set these as environment variables in the dashboard instead.

# -------------------------
# Required
# -------------------------

# Gmail account that sends the nightly reports
GMAIL_USER=youremail@gmail.com

# Gmail App Password (NOT your regular Gmail password)
# Generate one: myaccount.google.com > Security > 2-Step Verification > App passwords
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Flask session secret — use a long random string in production
# Generate one: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-a-long-random-string

# -------------------------
# Optional
# -------------------------

# Display name shown in the From field of emails
EMAIL_FROM_NAME=NCAA Player Tracker

# ScraperAPI key — needed to scrape stats.ncaa.org (Akamai-protected)
# Free tier: 1,000 requests/month.  Sign up at scraperapi.com
# Leave blank to use manual stat entry via the web UI instead.
SCRAPERAPI_KEY=

# Set to true if your ScraperAPI plan includes Ultra Premium
SCRAPERAPI_ULTRA=false

# Directory where tracker.db is stored.
# In Railway: mount a Volume at /data and set DATA_DIR=/data so the database
# survives deploys.  Leave blank for local development (uses project folder).
DATA_DIR=

# Time (UTC, 24-hour HH:MM) at which the nightly scrape+email job runs.
# Default: 23:00 (11 PM UTC = 7 PM ET during daylight saving time)
NIGHTLY_RUN_AT=23:00

# Write logs to a file in addition to stdout.
# Leave blank on Railway (stdout is captured automatically).
# LOG_FILE=tracker.log

# Set to 1 to enable Flask debug mode (local dev only — never in production)
FLASK_DEBUG=0
